#include <Servo.h>

Servo radarServo;

int trigPin = 9;
int echoPin = 10;

long duration;
int distance;

void setup() {
  Serial.begin(9600);
  radarServo.attach(6);

  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
}

void loop() {

  for(int angle = 20; angle <= 160; angle+=2){

    radarServo.write(angle);
    delay(25);

    digitalWrite(trigPin, LOW);
    delayMicroseconds(2);

    digitalWrite(trigPin, HIGH);
    delayMicroseconds(10);
    digitalWrite(trigPin, LOW);

    duration = pulseIn(echoPin,HIGH);

    distance = duration * 0.034 / 2;

    Serial.print(angle);
    Serial.print(",");
    Serial.print(distance);
    Serial.println(".");
  }

  for(int angle = 160; angle >= 20; angle-=2){

    radarServo.write(angle);
    delay(25);

    digitalWrite(trigPin, LOW);
    delayMicroseconds(2);

    digitalWrite(trigPin, HIGH);
    delayMicroseconds(10);
    digitalWrite(trigPin, LOW);

    duration = pulseIn(echoPin,HIGH);

    distance = duration * 0.034 / 2;

    Serial.print(angle);
    Serial.print(",");
    Serial.print(distance);
    Serial.println(".");
  }
}
